<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="32dp">

        <!-- Title -->
        <TextView
            android:id="@+id/setupTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_welcome_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:paddingBottom="8dp"/>

        <TextView
            android:id="@+id/setupDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_welcome_desc"
            android:textSize="15sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingBottom="32dp"/>

        <!-- PIN Input (reused for all PIN steps) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/pinCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="@color/card"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/pinLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Set PIN"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:paddingBottom="16dp"/>

                <EditText
                    android:id="@+id/inputPin"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:background="@drawable/search_background"
                    android:gravity="center"
                    android:hint="Enter 4-6 digit PIN"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="24sp"
                    android:inputType="numberPassword"
                    android:maxLength="6"
                    android:paddingHorizontal="16dp"/>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Space for content -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:minHeight="32dp"/>

        <!-- Navigation -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="24dp">

            <Button
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_back"
                android:visibility="gone"/>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <Button
                android:id="@+id/btnSkip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_skip"
                android:visibility="gone"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/setup_next"
                android:layout_marginStart="12dp"/>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
