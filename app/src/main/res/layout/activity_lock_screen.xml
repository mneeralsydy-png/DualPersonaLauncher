<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/lockRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lock_background"
    android:clipToPadding="false">

    <!-- Time Display -->
    <TextClock
        android:id="@+id/textClock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:format12Hour="hh:mm"
        android:format24Hour="HH:mm"
        android:textColor="@android:color/white"
        android:textSize="72sp"
        
        android:letterSpacing="0.02"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="80dp"/>

    <TextView
        android:id="@+id/textDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#B0BEC5"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/textClock"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="8dp"
        tools:text="Wednesday, January 15"/>

    <!-- Environment Label -->
    <TextView
        android:id="@+id/textEnvironmentLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:alpha="0.7"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/textDate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"
        tools:text="Switching to Hidden Space"/>

    <!-- PIN Dots Indicator -->
    <LinearLayout
        android:id="@+id/pinDotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="48dp"
        app:layout_constraintTop_toBottomOf="@id/textEnvironmentLabel"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <View android:id="@+id/dot1" style="@style/LockPinDot" android:background="@drawable/pin_dot_inactive"/>
        <View android:id="@+id/dot2" style="@style/LockPinDot" android:layout_marginStart="16dp" android:background="@drawable/pin_dot_inactive"/>
        <View android:id="@+id/dot3" style="@style/LockPinDot" android:layout_marginStart="16dp" android:background="@drawable/pin_dot_inactive"/>
        <View android:id="@+id/dot4" style="@style/LockPinDot" android:layout_marginStart="16dp" android:background="@drawable/pin_dot_inactive"/>
        <View android:id="@+id/dot5" style="@style/LockPinDot" android:layout_marginStart="16dp" android:background="@drawable/pin_dot_inactive" android:visibility="gone"/>
        <View android:id="@+id/dot6" style="@style/LockPinDot" android:layout_marginStart="16dp" android:background="@drawable/pin_dot_inactive" android:visibility="gone"/>

    </LinearLayout>

    <!-- Error Message -->
    <TextView
        android:id="@+id/textError"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/lock_screen_error_wrong_pin"
        android:textColor="@color/lock_error"
        android:textSize="14sp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/pinDotsContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="16dp"/>

    <!-- Attempt Counter -->
    <TextView
        android:id="@+id/textAttempts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#FF8A80"
        android:textSize="12sp"
        android:visibility="invisible"
        app:layout_constraintTop_toBottomOf="@id/textError"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="4dp"
        tools:text="3 attempts remaining"/>

    <!-- Number Pad -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/keypadContainer"
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <!-- Row 1: 1, 2, 3 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn1"
            style="@style/LockNumberButton"
            android:text="1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn2"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn2"
            style="@style/LockNumberButton"
            android:text="2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn1"
            app:layout_constraintEnd_toStartOf="@id/btn3"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn3"
            style="@style/LockNumberButton"
            android:text="3"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/btn2"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 2: 4, 5, 6 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn4"
            style="@style/LockNumberButton"
            android:text="4"
            app:layout_constraintTop_toBottomOf="@id/btn1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn5"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn5"
            style="@style/LockNumberButton"
            android:text="5"
            app:layout_constraintTop_toBottomOf="@id/btn1"
            app:layout_constraintStart_toEndOf="@id/btn4"
            app:layout_constraintEnd_toStartOf="@id/btn6"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn6"
            style="@style/LockNumberButton"
            android:text="6"
            app:layout_constraintTop_toBottomOf="@id/btn1"
            app:layout_constraintStart_toEndOf="@id/btn5"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 3: 7, 8, 9 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn7"
            style="@style/LockNumberButton"
            android:text="7"
            app:layout_constraintTop_toBottomOf="@id/btn4"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn8"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn8"
            style="@style/LockNumberButton"
            android:text="8"
            app:layout_constraintTop_toBottomOf="@id/btn4"
            app:layout_constraintStart_toEndOf="@id/btn7"
            app:layout_constraintEnd_toStartOf="@id/btn9"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn9"
            style="@style/LockNumberButton"
            android:text="9"
            app:layout_constraintTop_toBottomOf="@id/btn4"
            app:layout_constraintStart_toEndOf="@id/btn8"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Row 4: Fingerprint, 0, Delete -->
        <ImageButton
            android:id="@+id/btnFingerprint"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_lock_lock"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Fingerprint"
            android:scaleType="centerInside"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/btn7"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btn0"
            app:tint="#FFFFFF"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn0"
            style="@style/LockNumberButton"
            android:text="0"
            app:layout_constraintTop_toBottomOf="@id/btn7"
            app:layout_constraintStart_toEndOf="@id/btnFingerprint"
            app:layout_constraintEnd_toStartOf="@id/btnDelete"/>

        <ImageButton
            android:id="@+id/btnDelete"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_input_delete"
            android:background="?selectableItemBackgroundBorderless"
            android:contentDescription="Delete"
            android:scaleType="centerInside"
            app:layout_constraintTop_toBottomOf="@id/btn7"
            app:layout_constraintStart_toEndOf="@id/btn0"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="#FFFFFF"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom Actions -->
    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="40dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEmergency"
            style="@style/LockActionButton"
            android:text="SOS"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#FF5252"
            android:visibility="gone"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
