<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:id="@+id/tv_dashboard_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Control Panel"
            android:textSize="24sp"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Accessed via secret code"
            android:textSize="12sp"
            android:textColor="@color/text_secondary"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- ===== Profile A Card ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile A (Main)"
                    android:textSize="12sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_a_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="User A"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_a_cred"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="PIN"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Profile B Card ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Profile B (Secondary)"
                    android:textSize="12sp"
                    android:textColor="@color/accent"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_b_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="User B"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_profile_b_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Not Created"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== System Status Card ===== -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="@color/bg_card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Status"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold"
                    android:paddingBottom="8dp" />

                <TextView
                    android:id="@+id/tv_isolation_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Isolation: Checking..."
                    android:textSize="14sp"
                    android:textColor="@color/text_primary"
                    android:drawablePadding="8dp" />

                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Services: Checking..."
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/tv_stealth_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Stealth: Checking..."
                    android:textSize="14sp"
                    android:textColor="@color/text_primary" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ===== Action Buttons ===== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp">

            <Button
                android:id="@+id/btn_switch_to_b"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="Switch to Profile B"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/accent" />

            <Button
                android:id="@+id/btn_switch_to_a"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="8dp"
                android:text="Switch to Profile A"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/primary" />

            <Button
                android:id="@+id/btn_check_isolation"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:text="Run Isolation Check"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/transparent"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btn_view_logs"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:text="View Security Logs"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/transparent"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btn_change_secret"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:text="Change Secret Code"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/transparent"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btn_toggle_stealth"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:text="Toggle Stealth Mode"
                android:textColor="@color/primary"
                android:backgroundTint="@android:color/transparent"
                style="?android:attr/borderlessButtonStyle" />

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginBottom="4dp"
                android:text="Refresh Status"
                android:textColor="@color/text_secondary"
                android:backgroundTint="@android:color/transparent"
                style="?android:attr/borderlessButtonStyle" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_reset"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Reset System"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/danger" />

        </LinearLayout>

        <!-- Bottom padding -->
        <View
            android:layout_width="0dp"
            android:layout_height="32dp" />

    </LinearLayout>

</ScrollView>
