<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DualPersona" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
    </style>

    <style name="Theme.DualPersona.Splash" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:windowFullscreen">true</item>
    </style>

    <style name="Theme.DualPersona.LockScreen" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Theme.DualPersona.Launcher" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.DualPersona.Setup" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="LockPinDot">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
    </style>

    <style name="LockNumberButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">72dp</item>
        <item name="android:layout_height">72dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@android:color/white</item>
    </style>

    <style name="SettingsItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:background">?selectableItemBackground</item>
    </style>
    <style name="LockActionButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
    </style>
</resources>
