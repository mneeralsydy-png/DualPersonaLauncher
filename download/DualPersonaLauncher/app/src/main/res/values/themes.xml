<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Application Theme -->
    <style name="Theme.DualPersona" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:statusBarColor">@color/transparent</item>
        <item name="android:navigationBarColor">@color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.DualPersona.Splash" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Lock Screen Theme -->
    <style name="Theme.DualPersona.LockScreen" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/lock_background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowShowWallpaper">false</item>
        <item name="android:windowAnimationStyle">@null</item>
    </style>

    <!-- Launcher Theme -->
    <style name="Theme.DualPersona.Launcher" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- Setup Theme -->
    <style name="Theme.DualPersona.Setup" parent="Theme.DualPersona">
        <item name="android:windowBackground">@color/background</item>
    </style>

    <!-- Lock Screen PIN Dot -->
    <style name="LockPinDot">
        <item name="android:layout_width">20dp</item>
        <item name="android:layout_height">20dp</item>
        <item name="android:shape">oval</item>
    </style>

    <!-- Lock Screen Number Button -->
    <style name="LockNumberButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">80dp</item>
        <item name="android:layout_height">80dp</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:backgroundTint">@color/semi_transparent</item>
        <item name="cornerRadius">40dp</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Lock Screen Action Button -->
    <style name="LockActionButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:layout_width">60dp</item>
        <item name="android:layout_height">60dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="android:backgroundTint">@color/transparent</item>
        <item name="cornerRadius">30dp</item>
    </style>

    <!-- App Icon Style -->
    <style name="AppIconContainer">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:gravity">center</item>
        <item name="android:orientation">vertical</item>
        <item name="android:padding">8dp</item>
    </style>

    <!-- Settings Item -->
    <style name="SettingsItem">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">20dp</item>
        <item name="android:paddingVertical">16dp</item>
        <item name="android:background">?selectableItemBackground</item>
    </style>

    <!-- Space Badge -->
    <style name="SpaceBadge">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">24dp</item>
        <item name="android:paddingHorizontal">12dp</item>
        <item name="android:gravity">center</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_on_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>
</resources>
