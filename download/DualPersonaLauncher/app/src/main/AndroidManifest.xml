<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== صلاحيات ===== -->
    <!-- تمت إزالة صلاحيات النظام غير القابلة للمنح (MANAGE_USERS, INTERACT_ACROSS_USERS) -->
    <!-- لأنها مخصصة للتطبيقات النظامية فقط وتسبب انهيار التطبيق -->

    <!-- إعادة التشغيل -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- الخدمات الأمامية -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- البصمة -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- الإشعارات -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- الشبكة -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
        android:name=".DualPersonaApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.DualPersona"
        tools:targetApi="34">

        <!-- ===== الأنشطة الرئيسية ===== -->

        <!-- معالج الإعداد -->
        <activity
            android:name=".ui.setup.SetupWizardActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:taskAffinity=""
            android:excludeFromRecents="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- لوحة التحكم المخفية -->
        <activity
            android:name=".ui.dashboard.DashboardActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:theme="@style/Theme.DualPersona.Stealth" />

        <!-- ===== مسؤول الجهاز ===== -->
        <receiver
            android:name=".receiver.DualPersonaAdmin"
            android:exported="true"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLE_REQUESTED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLED" />
                <action android:name="android.app.action.ACTION_PASSWORD_CHANGED" />
                <action android:name="android.app.action.ACTION_PASSWORD_FAILED" />
                <action android:name="android.app.action.ACTION_PASSWORD_SUCCEEDED" />
            </intent-filter>
        </receiver>

        <!-- ===== مستقبلات البث ===== -->

        <!-- مستقبل إعادة التشغيل -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- مستقبل تبديل المستخدم -->
        <receiver
            android:name=".receiver.UserSwitchReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.USER_SWITCHED" />
                <action android:name="android.intent.action.USER_FOREGROUND" />
                <action android:name="android.intent.action.USER_BACKGROUND" />
            </intent-filter>
        </receiver>

        <!-- مستقبل الرمز السري -->
        <receiver
            android:name=".receiver.SecretDialReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SECRET_CODE" />
                <data android:scheme="android_secret_code" />
            </intent-filter>
        </receiver>

        <!-- ===== الخدمات الأمامية ===== -->

        <!-- خدمة النظام -->
        <service
            android:name=".service.SystemService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Dual persona user management" />
        </service>

        <!-- خدمة الحماية -->
        <service
            android:name=".service.GuardService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Security monitoring" />
        </service>

        <!-- ===== مزودو الخدمات ===== -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

    </application>

</manifest>
